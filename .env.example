# StockOps AI Module — Environment Configuration
# Public-safe template only. Copy to .env locally or inject through a secret manager.
# Never commit real passwords, API keys, or private network endpoints.

# Required: PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://stockops:change-me-locally@localhost:5432/stockops

# Optional: Service bind host
SERVICE_HOST=0.0.0.0

# Optional: Service bind port
SERVICE_PORT=8000

# Optional: Prophet model cache TTL in seconds
MODEL_CACHE_TTL_SECONDS=3600

# Optional: Maximum number of cached Prophet models, LRU eviction
MODEL_CACHE_MAX_SIZE=10

# Optional: Minimum historical data days required for training
MIN_HISTORY_DAYS=14

# Optional: MAPE threshold percent for logging warnings
MAPE_ALERT_THRESHOLD=30.0

# Optional: Train/test split ratio for model evaluation
EVALUATION_TRAIN_RATIO=0.8

# Optional: DB connection pool minimum connections
DB_POOL_MIN=2

# Optional: DB connection pool maximum connections
DB_POOL_MAX=10

# Optional: DB connection timeout in seconds
DB_CONNECT_TIMEOUT=10

# Optional: API key for /predict and /evaluate endpoints. Leave empty to disable auth in dev.
AI_MODULE_API_KEY=
